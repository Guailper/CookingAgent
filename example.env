# App
APP_SECRET_KEY=change-this-in-dev
APP_DEBUG=false
AUTO_CREATE_TABLES=true

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cooking_agent_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4

# Agent model
AGENT_MODEL_PROVIDER=kimi
AGENT_MODEL_FALLBACK_ORDER=kimi,xiaomi,aihubmix,local
AGENT_TEMPERATURE=0.4
AGENT_MAX_OUTPUT_TOKENS=800
AGENT_REQUEST_TIMEOUT_SECONDS=90
AGENT_MAX_CONTEXT_MESSAGES=10

# Kimi / Moonshot
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL_ID=kimi-k2.6

# Optional fallback providers
XIAOMI_BASE_URL=
XIAOMI_API_KEY=
XIAOMI_MODEL_ID=
AIHUBMIX_BASE_URL=
AIHUBMIX_API_KEY=
AIHUBMIX_MODEL_ID=gpt-4o-mini
LOCAL_MODEL_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL_API_KEY=not-needed
LOCAL_MODEL_ID=

# RAG and Milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
MILVUS_COLLECTION=rag_chunks
RAG_DEFAULT_KNOWLEDGE_BASE_IDS=cookbook
RAG_VECTOR_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_MIN_SCORE=0.25
RAG_QUERY_REWRITE_ENABLED=true
RAG_EMBEDDING_PROVIDER=local_huggingface
RAG_EMBEDDING_MODEL_PATH=models/bge-small-zh-v1.5
RAG_RERANK_PROVIDER=local_huggingface
RAG_RERANK_MODEL_PATH=models/bge-reranker-v2-m3

# MinerU attachment parsing
MINERU_COMMAND=mineru
MINERU_OUTPUT_DIR=backend/uploads/mineru
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_API_URL=
MINERU_PARSE_TIMEOUT_SECONDS=1800
MINERU_EXTRA_ARGS=

# External tools
SERPAPI_API_KEY=
WEATHER_API_KEY=

# Voice
VOICE_TRANSCRIBE_PROVIDER=local_faster_whisper
VOICE_LOCAL_MODEL=small
VOICE_LOCAL_DEVICE=auto

# Redis
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
